{
	"name": "hamverbot",
	"private": true,
	"type": "module",
	"module": "index.ts",
	"scripts": {
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --minify --target bun --outfile hamverbot.ts",
		"schema:sync": "bun run scripts/sync-turso-schema.ts",
		"test": "bun test",
		"format": "oxfmt --check .",
		"format:write": "oxfmt --write .",
		"lint": "oxlint --type-aware .",
		"lint:fix": "oxlint --type-aware . --fix",
		"typecheck": "tsgo --noEmit -p tsconfig.json",
		"check": "bun run typecheck && bun run format && bun run lint"
	},
	"dependencies": {
		"@libsql/client": "^0.17.3",
		"@microsoft/signalr": "^10.0.0",
		"cron": "^4.4.0",
		"dotenv": "^17.4.2",
		"irc-framework": "^4.14.0",
		"node-ical": "^0.26.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "^1.3.13",
		"@typescript/native-preview": "^7.0.0-dev.20260503.1",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"typescript": "^6.0.3"
	}
}
